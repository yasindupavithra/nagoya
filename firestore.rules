rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /vehicles/{vehicle} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /inquiries/{inquiry} {
      allow read, update, delete: if request.auth != null;
      allow create: if true;
    }
  }
}
